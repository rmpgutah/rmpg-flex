# ─── RMPG Flex Server Configuration ─────────────────
# Copy this file to .env and update values for your environment

# JWT Configuration
JWT_SECRET=CHANGE_ME_TO_A_SECURE_RANDOM_STRING
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Server
PORT=3001
NODE_ENV=development

# Security
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Password Policy
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_NUMBER=true
PASSWORD_REQUIRE_SPECIAL=false

# Session
SESSION_MAX_PER_USER=5

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:4173,https://rmpgutah.us

# Auto-Update Server (URL where desktop apps check for updates)
UPDATE_SERVER_URL=https://rmpgutah.us

# SSL/TLS Certificates (for rmpgutah.us hosting)
# SSL_CERT_PATH=/path/to/fullchain.pem
# SSL_KEY_PATH=/path/to/privkey.pem
# HTTPS_PORT=443
# SSL_HTTP_REDIRECT=true
# SSL_HTTP_REDIRECT_PORT=80
