{
  "name": "rmpg-flex-server",
  "version": "5.8.4",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "npx tsx watch src/index.ts",
    "dev:worker": "wrangler dev",
    "build": "tsc",
    "build:worker": "wrangler deploy --dry-run",
    "start": "node dist/index.js",
    "deploy": "bash ../deploy/deploy.sh",
    "deploy:staging": "bash ../deploy/deploy.sh --staging",
    "deploy:dry-run": "bash ../deploy/deploy.sh --dry-run",
    "seed": "npx tsx src/seeds/seed.ts",
    "scrapers": "npx tsx scripts/scrapers.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "check:routes": "node scripts/check-duplicate-routes.mjs",
    "d1:migrations:new": "wrangler d1 migrations create rmpg-flex",
    "d1:migrations:apply": "wrangler d1 migrations apply rmpg-flex",
    "d1:export": "wrangler d1 export rmpg-flex",
    "d1:import": "wrangler d1 import rmpg-flex"
  },
  "dependencies": {
    "@azure/msal-node": "^5.2.2",
    "@cloudflare/workers-types": "^4.20260524.1",
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "@simplewebauthn/server": "^13.2.3",
    "@types/luxon": "^3.7.1",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.10.0",
    "cheerio": "^1.2.0",
    "cors": "^2.8.5",
    "csv-parse": "^6.2.1",
    "csv-stringify": "^6.7.0",
    "dotenv": "^17.3.1",
    "edge-tts-universal": "^1.4.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.1",
    "groq-sdk": "^1.1.1",
    "hono": "^4.12.22",
    "html-to-text": "^10.0.0",
    "jose": "^6.2.3",
    "jsonwebtoken": "^9.0.2",
    "jspdf": "^4.2.0",
    "luxon": "^3.7.2",
    "marked": "^18.0.3",
    "multer": "^2.1.1",
    "natural": "^8.1.1",
    "nodemailer": "^8.0.7",
    "otpauth": "^9.5.1",
    "pdf-parse": "^2.4.5",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "qrcode": "^1.5.4",
    "robots-parser": "^3.0.1",
    "rss-parser": "^3.13.0",
    "sanitize-html": "^2.17.4",
    "sentiment": "^5.0.2",
    "stream-json": "^2.1.0",
    "turndown": "^7.2.2",
    "uuid": "^14.0.0",
    "whois-json": "^2.0.4",
    "ws": "^8.20.1"
  },
  "overrides": {
    "dompurify": "file:./stubs/dompurify",
    "uuid": "$uuid"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/html-to-text": "^9.0.4",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^2.0.0",
    "@types/nodemailer": "^8.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/sanitize-html": "^2.16.1",
    "@types/supertest": "^7.2.0",
    "@types/turndown": "^5.0.6",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.13",
    "@vitest/coverage-v8": "^4.1.7",
    "pino-pretty": "^13.1.3",
    "supertest": "^7.2.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.0",
    "vitest": "^4.1.5",
    "wrangler": "^4.94.0"
  }
}
