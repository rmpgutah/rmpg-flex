# ============================================================
# RMPG Flex — Client Environment Variables
# Copy this file to .env and fill in values.
# ============================================================

# Google Maps API Key (required for map, address search, routing)
# Get one from: https://console.cloud.google.com/apis/credentials
# Enable: Maps JavaScript API, Places API (New)
VITE_GOOGLE_MAPS_API_KEY=

# Google Maps Map ID (optional — enables cloud-based map styling
# and AdvancedMarkerElement). Create one at:
# https://console.cloud.google.com/google/maps-apis/studio/maps
# VITE_GOOGLE_MAPS_MAP_ID=
