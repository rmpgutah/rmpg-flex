{
  "name": "rmpg-flex-desktop",
  "version": "5.8.4",
  "description": "RMPG Flex CAD/RMS — Desktop Application",
  "author": "Rocky Mountain Protective Group",
  "license": "UNLICENSED",
  "private": true,
  "main": "main.js",
  "scripts": {
    "start": "electron . --dev",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:all": "electron-builder --mac --win"
  },
  "build": {
    "appId": "com.rmpg.flex",
    "productName": "RMPG Flex",
    "copyright": "Copyright (c) Rocky Mountain Protective Group, LLC",
    "afterPack": "./scripts/afterPack.cjs",
    "directories": {
      "output": "dist"
    },
    "publish": {
      "provider": "generic",
      "url": "https://rmpgutah.us/releases/"
    },
    "files": [
      "main.js",
      "preload.js",
      "updater.js",
      "localDb.js",
      "connectivityMonitor.js",
      "pinManager.js",
      "offlineRouter.js",
      "syncManager.js",
      "originalCatalog.json"
    ],
    "extraResources": [
      {
        "from": "../client/public/rmpg-seal.png",
        "to": "icon.png"
      },
      {
        "from": "../client/public/rmpg flex.png",
        "to": "rmpg flex.png"
      }
    ],
    "mac": {
      "category": "public.app-category.business",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "icon": "../client/public/rmpg-seal.icns",
      "darkModeSupport": true,
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "dmg": {
      "backgroundColor": "#000000",
      "title": "RMPG Flex Installer"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "../client/public/rmpg-seal.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "../client/public/rmpg-seal.ico",
      "uninstallerIcon": "../client/public/rmpg-seal.ico",
      "installerHeaderIcon": "../client/public/rmpg-seal.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "RMPG Flex"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Office",
      "icon": "../client/public/rmpg-seal.png"
    }
  },
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "electron": "^40.9.3",
    "electron-builder": "^26.0.0"
  },
  "overrides": {
    "@xmldom/xmldom": "0.8.13",
    "lodash": ">=4.18.0",
    "tar": ">=6.2.1"
  }
}
