#!/usr/bin/env sh
# Husky pre-push hook — last local guardrail before code reaches GitHub.
#
# Layered gate architecture (Cloudflare Workers era):
#   1. Husky pre-push (here)  — fast, local, runs on every `git push`
#   2. GitHub Actions PR tests — runs in CI on PR open/update and push to main
#   3. deploy.yml (Cloudflare)  — auto-deploys Worker + Pages on push to main
#
# Emergency bypass: `git push --no-verify` — CI (layer 2) and Cloudflare's
# build (layer 3) will still catch regressions.

set -e

ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"

# Skip when nothing to push (rebase/force-push flows, already-pushed branches).
if [ "$(git rev-list --count HEAD ^origin/main 2>/dev/null || echo 0)" = "0" ]; then
  echo "⤷ pre-push: no commits ahead of origin/main — skipping gate"
  exit 0
fi

ensure_deps() {
  dir="$1"
  if [ ! -d "$dir/node_modules" ]; then
    echo "  (installing $dir deps — worktree missing node_modules)"
    (cd "$dir" && npm install --silent --no-audit --no-fund) || {
      echo "✗ pre-push: npm install failed in $dir"
      exit 1
    }
  fi
}

printf '⤷ pre-push: quality gate (worker types + client types + client tests)\n'
START=$(date +%s)

ensure_deps "$ROOT"
ensure_deps "$ROOT/client"

echo "  [1/3] Worker TypeScript..."
(cd "$ROOT" && npx tsc --noEmit) || {
  echo "✗ pre-push: worker typecheck failed — run 'npx tsc --noEmit' to see errors"
  exit 1
}

echo "  [2/3] Client TypeScript..."
(cd "$ROOT/client" && npx tsc --noEmit) || {
  echo "✗ pre-push: client typecheck failed — run 'cd client && npx tsc --noEmit' to see errors"
  exit 1
}

echo "  [3/3] Client vitest..."
(cd "$ROOT/client" && npx vitest run --reporter=dot) || {
  echo "✗ pre-push: client tests failed — run 'cd client && npx vitest run' to see failures"
  echo "           (use 'git push --no-verify' to bypass in an emergency; CI will still gate the PR)"
  exit 1
}

END=$(date +%s)
printf '✓ pre-push: all gates passed in %ss\n' "$((END - START))"
