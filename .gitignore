# ─── Dependencies ──────────────────────────────────
node_modules/

# ─── Environment Variables (contain secrets) ───────
.env
client/.env
server/.env

# ─── Build Output ──────────────────────────────────
client/dist/
server/dist/

# ─── Database & Uploads (local data) ──────────────
server/data/
server/uploads/

# ─── Intake Calibration Samples ──────────────────
# Real client documents dropped for OCR calibration MUST NOT
# enter the repo. The directory structure + README are tracked;
# the PDFs/text/JSON inside are not.
tmp/intake-samples/**/*.pdf
tmp/intake-samples/**/*.txt
tmp/intake-samples/**/*.json
tmp/intake-samples/**/*.PDF

# ─── Binary Installers (too large for git) ────────
server/downloads/*.exe
server/downloads/*.exe.blockmap
server/downloads/*.dmg
server/downloads/*.dmg.blockmap
server/downloads/*.apk
server/downloads/*.zip

# ─── Certificates ────────────────────────────────
server/certs/

# ─── Environment Production ──────────────────────
server/.env.production

# ─── Android Build Artifacts ─────────────────────
client/android/.gradle/
client/android/app/build/
client/android/build/
client/android/.idea/
client/android/local.properties

# ─── Desktop/Electron Build Artifacts ────────────
desktop/dist/
desktop/out/

# ─── OS Generated Files ───────────────────────────
.DS_Store
Thumbs.db

# ─── IDE / Editor ─────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ─── Logs ─────────────────────────────────────────
*.log
npm-debug.log*
firebase-debug.log

# ─── TypeScript Cache ─────────────────────────────
*.tsbuildinfo
.claude/
.github/*
!.github/dependabot.yml
!.github/labeler.yml
!.github/SECURITY.md
!.github/CODEOWNERS
!.github/PULL_REQUEST_TEMPLATE.md
!.github/ISSUE_TEMPLATE/
!.github/workflows/
.firecrawl/

# ─── Visual Studio IDE state (should never be committed) ─────
.vs/
*.sln
*.vcxproj
*.vcxproj.filters
*.vcxproj.user
RMPG Flare/

client/RMPG-Dispatch-Guide-*.pdf
