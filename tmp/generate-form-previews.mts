const outputDir = '/Users/rmpgutah/Documents/Playground/rmpg-flex/tmp/pdf-preview';
fs.mkdirSync(outputDir, { recursive: true });

function writePdf(name: string, doc: { output: () => string }) {
  const pdfPath = path.join(outputDir, `${name}.pdf`);
  const pdfRaw = doc.output();
  fs.writeFileSync(pdfPath, pdfRaw, 'binary');
  return pdfPath;
}

